{
  "name": "@gemini-hlsw/lucuma-ts",
  "description": "Monorepo for navigate typescript projects",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.13.1",
  "license": "BSD-3-Clause",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git"
  },
  "scripts": {
    "ui": "pnpm --filter @gemini-hlsw/navigate-ui",
    "configs": "pnpm --filter @gemini-hlsw/navigate-configs",
    "e2e": "pnpm --filter @gemini-hlsw/navigate-e2e",
    "resource-ui": "pnpm --filter @gemini-hlsw/resource-ui",
    "admin-ui": "pnpm --filter @gemini-hlsw/admin-ui",
    "all": "pnpm -r",
    "lint": "pnpm lint:prettier && pnpm lint:style",
    "lint:prettier": "prettier --check .",
    "lint:style": "stylelint 'packages/*/src/**/*.css'",
    "tsc:watch": "tsc --build --watch",
    "prepare": "node .husky/install.js"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@parcel/watcher": "2.5.6",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/node26": "26.0.0",
    "@types/node": "26.1.1",
    "eslint": "10.7.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright": "1.61.1",
    "prettier": "3.9.5",
    "prettier-plugin-tailwindcss": "0.8.1",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,jsx,css,md,json,yml,yaml}": "prettier --write",
    "*.css": "stylelint --fix"
  }
}
