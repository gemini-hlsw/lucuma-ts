{
  "name": "@gemini-hlsw/lucuma-ts",
  "description": "Monorepo for navigate typescript projects",
  "version": "1.0.0",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "license": "BSD-3-Clause",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git"
  },
  "scripts": {
    "ui": "pnpm --filter @gemini-hlsw/navigate-ui",
    "configs": "pnpm --filter @gemini-hlsw/navigate-configs",
    "e2e": "pnpm --filter @gemini-hlsw/navigate-e2e",
    "resource-ui": "pnpm --filter @gemini-hlsw/resource-ui",
    "all": "pnpm -r",
    "lint": "pnpm lint:prettier && pnpm lint:style",
    "lint:prettier": "prettier --check .",
    "lint:style": "stylelint 'packages/*/src/**/*.css'",
    "tsc:watch": "tsc --build --watch",
    "prepare": "node .husky/install.js"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@graphql-codegen/cli": "7.1.3",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@parcel/watcher": "2.5.6",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.2",
    "@tsconfig/node-ts": "23.6.4",
    "@tsconfig/node26": "26.0.0",
    "@tsconfig/strictest": "2.0.8",
    "@tsconfig/vite-react": "8.0.6",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.9",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "9.39.4",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "playwright": "1.61.1",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sass": "1.101.0",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vite-plugin-mkcert": "2.1.0",
    "vitest": "4.1.9",
    "vitest-browser-react": "2.2.0"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx,jsx,css,md,json,yml,yaml}": "prettier --write",
    "*.css": "stylelint --fix"
  }
}
