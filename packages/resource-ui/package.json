{
  "name": "@gemini-hlsw/resource-ui",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git",
    "directory": "packages/resource-ui"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock-server": "node --watch --enable-source-maps ./mock-server/server.ts",
    "codegen": "graphql-codegen --config tasks/codegen.ts",
    "prebuild": "pnpm run codegen",
    "test": "vitest run",
    "build": "tsc && vite build",
    "lint:eslint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/pro-regular-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "primereact": "10.9.7",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "7.14.2"
  },
  "devDependencies": {
    "@apollo/client": "4.1.9",
    "@gemini-hlsw/lucuma-common-ui": "workspace:*",
    "@gemini-hlsw/lucuma-ui-css": "0.176.0",
    "@graphql-codegen/client-preset": "5.3.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "graphql": "16.13.2",
    "graphql-scalars": "1.25.0",
    "graphql-ws": "6.0.8",
    "graphql-yoga": "5.21.0"
  },
  "bundlemon": {
    "baseDir": "./dist",
    "pathLabels": {
      "hash": "[a-zA-Z0-9\\-_]+"
    },
    "files": [
      {
        "path": "assets/*-<hash>.{js,css}"
      }
    ],
    "reportOutput": [
      "github"
    ]
  }
}
