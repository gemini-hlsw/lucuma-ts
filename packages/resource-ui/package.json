{
  "name": "@gemini-hlsw/resource-ui",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git",
    "directory": "packages/resource-ui"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock-server": "node --conditions=development --watch --enable-source-maps ./mock-server/server.ts",
    "codegen": "graphql-codegen --config tasks/codegen.ts",
    "codegen:mock": "graphql-codegen --config tasks/codegen.mock.ts",
    "ci:set-deploy-flag": "echo \"should_deploy=true\" >> \"$GITHUB_OUTPUT\"",
    "prebuild": "pnpm run codegen",
    "test": "vitest run",
    "build": "tsc -b && vite build",
    "lint:eslint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@apollo/client": "4.2.7",
    "@fortawesome/fontawesome-svg-core": "7.3.1",
    "@fortawesome/pro-regular-svg-icons": "7.3.1",
    "@fortawesome/react-fontawesome": "3.4.0",
    "@gemini-hlsw/lucuma-common-ui": "workspace:*",
    "@gemini-hlsw/lucuma-ui-css": "0.176.0",
    "@highcharts/react": "5.2.2",
    "date-fns": "4.4.0",
    "highcharts": "13.0.0",
    "primereact": "10.9.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router": "8.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@gemini-hlsw/lucuma-schemas": "0.177.2-20260717-155f8e72",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-codegen/client-preset": "6.1.0",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@rolldown/plugin-babel": "0.2.3",
    "@tailwindcss/vite": "4.3.3",
    "@tsconfig/strictest": "2.0.8",
    "@tsconfig/vite-react": "8.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser-playwright": "4.1.10",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "10.7.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "globals": "17.7.0",
    "graphql": "16.14.2",
    "graphql-scalars": "1.25.0",
    "graphql-ws": "6.1.0",
    "graphql-yoga": "5.21.2",
    "playwright": "1.61.1",
    "sass": "1.101.0",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  },
  "bundlemon": {
    "baseDir": "./dist",
    "pathLabels": {
      "hash": "[a-zA-Z0-9\\-_]+"
    },
    "files": [
      {
        "path": "assets/*-<hash>.{js,css}"
      }
    ],
    "reportOutput": [
      "github"
    ]
  }
}
