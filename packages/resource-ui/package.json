{
  "name": "@gemini-hlsw/resource-ui",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git",
    "directory": "packages/resource-ui"
  },
  "scripts": {
    "dev": "vite",
    "dev:mock-server": "node --conditions=development --watch --enable-source-maps ./mock-server/server.ts",
    "codegen": "graphql-codegen --config tasks/codegen.ts",
    "codegen:mock": "graphql-codegen --config tasks/codegen.mock.ts",
    "ci:set-deploy-flag": "echo \"should_deploy=true\" >> \"$GITHUB_OUTPUT\"",
    "prebuild": "pnpm run codegen",
    "test": "vitest run",
    "build": "tsc -b && vite build",
    "lint:eslint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@apollo/client": "catalog:",
    "@fortawesome/fontawesome-svg-core": "catalog:",
    "@fortawesome/pro-regular-svg-icons": "catalog:",
    "@fortawesome/react-fontawesome": "catalog:",
    "@gemini-hlsw/lucuma-common-ui": "workspace:*",
    "@gemini-hlsw/lucuma-ui-css": "catalog:",
    "@highcharts/react": "5.2.2",
    "date-fns": "catalog:",
    "highcharts": "12.6.0",
    "primereact": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@gemini-hlsw/lucuma-schemas": "catalog:",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/client-preset": "catalog:",
    "@graphql-eslint/eslint-plugin": "catalog:",
    "@graphql-typed-document-node/core": "catalog:",
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@tsconfig/vite-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "babel-plugin-react-compiler": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "globals": "catalog:",
    "graphql": "catalog:",
    "graphql-scalars": "catalog:",
    "graphql-ws": "catalog:",
    "graphql-yoga": "catalog:",
    "playwright": "catalog:",
    "sass": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:"
  },
  "bundlemon": {
    "baseDir": "./dist",
    "pathLabels": {
      "hash": "[a-zA-Z0-9\\-_]+"
    },
    "files": [
      {
        "path": "assets/*-<hash>.{js,css}"
      }
    ],
    "reportOutput": [
      "github"
    ]
  }
}
