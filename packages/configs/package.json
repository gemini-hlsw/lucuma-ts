{
  "name": "@gemini-hlsw/navigate-configs",
  "version": "1.0.0",
  "main": "dist/index.js",
  "license": "BSD-3-Clause",
  "type": "module",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git",
    "directory": "packages/configs"
  },
  "exports": {
    ".": "./dist/index.js",
    "./db": "./dist/prisma/db.js"
  },
  "scripts": {
    "test": "pnpm test:integration",
    "test:integration": "node --test --enable-source-maps --test-timeout 20000 'src/integration/**/*.test.ts'",
    "generate": "prisma generate",
    "prebuild": "pnpm generate && pnpm codegen",
    "build": "tsc -b",
    "start": "pnpm build && pnpm preview",
    "preview": "node --enable-source-maps ./dist/index.js",
    "dev": "node --conditions=development --env-file=.env --watch --enable-source-maps ./src/index.ts",
    "codegen": "graphql-codegen --config tasks/codegen.ts",
    "codegen:watch": "pnpm codegen --watch 'src/graphql/**/*.ts' --watch 'src/graphql/*.graphql'",
    "lint:eslint": "eslint .",
    "production": "pnpm prisma migrate deploy && pnpm prisma db seed && pnpm preview"
  },
  "dependencies": {
    "@gemini-hlsw/lucuma-core": "0.219.1",
    "@gemini-hlsw/lucuma-schemas": "0.177.2-20260721-c8241473",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "graphql": "17.0.2",
    "graphql-parse-resolve-info": "4.14.1",
    "graphql-scalars": "1.25.0",
    "graphql-yoga": "5.21.2",
    "prisma": "7.8.0"
  },
  "devDependencies": {
    "@eddeee888/gcg-typescript-resolver-files": "0.17.0",
    "@eslint/js": "10.0.1",
    "@graphql-codegen/cli": "7.2.0",
    "@graphql-eslint/eslint-plugin": "4.4.0",
    "@testcontainers/postgresql": "12.0.4",
    "@tsconfig/strictest": "2.0.8",
    "eslint": "10.7.0",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-simple-import-sort": "14.0.0",
    "globals": "17.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0"
  },
  "files": [
    "dist",
    "prisma",
    "src",
    "tasks",
    "gen",
    "start-server.sh",
    "prisma.config.ts"
  ]
}
