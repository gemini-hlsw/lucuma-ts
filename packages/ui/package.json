{
  "name": "@gemini-hlsw/navigate-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "dev": "vite",
    "codegen:watch": "graphql-codegen --config tasks/codegen.ts --watch 'src/gql/**/*.ts' --watch '../configs/src/graphql/*.graphql'",
    "prebuild": "pnpm run codegen",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint:eslint": "eslint .",
    "codegen": "graphql-codegen --config tasks/codegen.ts"
  },
  "devDependencies": {
    "@apollo/client": "catalog:",
    "@eslint/js": "catalog:",
    "@fortawesome/fontawesome-svg-core": "catalog:",
    "@fortawesome/pro-regular-svg-icons": "catalog:",
    "@fortawesome/react-fontawesome": "catalog:",
    "@gemini-hlsw/lucuma-common-ui": "workspace:*",
    "@gemini-hlsw/lucuma-core": "catalog:",
    "@gemini-hlsw/lucuma-schemas": "catalog:",
    "@gemini-hlsw/lucuma-ui-css": "catalog:",
    "@gemini-hlsw/navigate-configs": "workspace:*",
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/client-preset": "catalog:",
    "@graphql-eslint/eslint-plugin": "catalog:",
    "@graphql-typed-document-node/core": "catalog:",
    "@rolldown/plugin-babel": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tsconfig/strictest": "catalog:",
    "@tsconfig/vite-react": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "@xyflow/react": "12.11.2",
    "babel-plugin-react-compiler": "catalog:",
    "date-fns": "catalog:",
    "eslint": "catalog:",
    "eslint-import-resolver-typescript": "catalog:",
    "eslint-plugin-react": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "eslint-plugin-simple-import-sort": "catalog:",
    "globals": "catalog:",
    "graphql": "catalog:",
    "graphql-ws": "catalog:",
    "jotai": "catalog:",
    "playwright": "catalog:",
    "primereact": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-router": "catalog:",
    "sass": "catalog:",
    "tailwind-merge": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vite": "catalog:",
    "vite-plugin-mkcert": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "catalog:"
  },
  "bundlemon": {
    "baseDir": "./dist",
    "pathLabels": {
      "hash": "[a-zA-Z0-9\\-_]+"
    },
    "files": [
      {
        "path": "assets/*-<hash>.{js,css}"
      }
    ],
    "reportOutput": [
      "github"
    ]
  }
}
