{
  "name": "@gemini-hlsw/navigate-ui",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "BSD-3-Clause",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gemini-hlsw/navigate-ts.git",
    "directory": "packages/ui"
  },
  "scripts": {
    "dev": "vite",
    "codegen:watch": "graphql-codegen --config tasks/codegen.ts --watch 'src/gql/**/*.ts' --watch '../configs/src/graphql/*.graphql'",
    "prebuild": "pnpm run codegen",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "lint:eslint": "eslint .",
    "codegen": "graphql-codegen --config tasks/codegen.ts"
  },
  "devDependencies": {
    "@apollo/client": "4.1.9",
    "@fortawesome/fontawesome-svg-core": "7.2.0",
    "@fortawesome/pro-regular-svg-icons": "7.2.0",
    "@fortawesome/react-fontawesome": "3.3.1",
    "@gemini-hlsw/lucuma-common-ui": "workspace:*",
    "@gemini-hlsw/lucuma-core": "0.198.0",
    "@gemini-hlsw/lucuma-schemas": "0.177.1-20260514-7cbecf8b",
    "@gemini-hlsw/lucuma-ui-css": "0.176.0",
    "@gemini-hlsw/navigate-configs": "workspace:*",
    "@graphql-codegen/client-preset": "6.0.0",
    "@graphql-typed-document-node/core": "3.2.0",
    "@xyflow/react": "12.10.2",
    "date-fns": "4.1.0",
    "graphql": "16.14.0",
    "graphql-ws": "6.0.8",
    "jotai": "2.20.0",
    "primereact": "10.9.8",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-router": "7.15.1",
    "tailwind-merge": "3.6.0"
  },
  "bundlemon": {
    "baseDir": "./dist",
    "pathLabels": {
      "hash": "[a-zA-Z0-9\\-_]+"
    },
    "files": [
      {
        "path": "assets/*-<hash>.{js,css}"
      }
    ],
    "reportOutput": [
      "github"
    ]
  }
}
